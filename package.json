{
  "name": "ptrst102-blog",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "fix": "run-s fix:*",
    "fix:biome": "npm run lint:biome -- --write",
    "fix:prettier": "npm run lint:prettier -- --write",
    "lint": "run-s lint:*",
    "lint:biome": "biome check .",
    "lint:prettier": "prettier . --check"
  },
  "dependencies": {
    "@astrojs/check": "0.9.8",
    "@astrojs/react": "5.0.2",
    "@astrojs/sitemap": "3.7.2",
    "@iconify-json/ic": "1.2.4",
    "@iconify-json/simple-icons": "1.2.75",
    "@tailwindcss/typography": "0.5.19",
    "@tailwindcss/vite": "4.2.2",
    "astro": "6.1.1",
    "astro-icon": "1.1.5",
    "astro-seo": "1.1.0",
    "cdate": "0.0.7",
    "daisyui": "5.5.19",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "remark-breaks": "4.0.0",
    "satori": "0.26.0",
    "sharp": "0.34.5",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "4.2.2",
    "typescript": "6.0.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@playform/compress": "0.2.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "npm-run-all2": "8.0.4",
    "prettier": "3.8.1",
    "prettier-plugin-astro": "0.14.1"
  },
  "volta": {
    "node": "24.14.1"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "@astrojs/check>typescript": "6",
        "tsconfck>typescript": "6",
        "zod-to-ts>typescript": "6"
      }
    }
  }
}
