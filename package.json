{
  "name": "ptrst102-blog",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "fix": "run-s fix:*",
    "fix:biome": "npm run lint:biome -- --write",
    "fix:prettier": "npm run lint:prettier -- --write",
    "lint": "run-s lint:*",
    "lint:biome": "biome check .",
    "lint:prettier": "prettier . --check"
  },
  "dependencies": {
    "@astrojs/check": "0.9.9",
    "@astrojs/react": "4.4.2",
    "@astrojs/sitemap": "3.7.3",
    "@iconify-json/ic": "1.2.4",
    "@iconify-json/simple-icons": "1.2.89",
    "@tailwindcss/typography": "0.5.20",
    "@tailwindcss/vite": "4.3.2",
    "astro": "5.18.2",
    "astro-icon": "1.1.5",
    "astro-seo": "1.1.0",
    "cdate": "0.0.7",
    "daisyui": "5.6.16",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "remark-breaks": "4.0.0",
    "satori": "0.26.0",
    "sharp": "0.35.3",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.2",
    "typescript": "6.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@playform/compress": "0.2.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "npm-run-all2": "8.0.4",
    "prettier": "3.9.4",
    "prettier-plugin-astro": "0.14.1"
  },
  "volta": {
    "node": "24.18.0"
  },
  "packageManager": "pnpm@10.34.4",
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "@astrojs/check>typescript": "6",
        "tsconfck>typescript": "6",
        "zod-to-ts>typescript": "6"
      }
    }
  }
}
